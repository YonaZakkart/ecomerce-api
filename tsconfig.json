{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    "forceConsistentCasingInFileNames": true,

    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],
    "lib": ["ES2020"],
    
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": ["src"]
}
